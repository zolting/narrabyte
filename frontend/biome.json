{
	"$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": true
	},

	"files": {
		"ignoreUnknown": false,
		"includes": [
			"src/**/*.ts",
			"!src/**/*.gen.ts",
			"!src/components/ui",
			"src/**/*.tsx",
			"src/**/*.json",
			"src/**/*.css",
			"src/**/*.md",
			"!!**/node_modules",
			"!!**/src/routeTree.gen.ts"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"bracketSpacing": true
	},
	"linter": {
		"enabled": true,
		"includes": ["src/**/*.ts", "src/**/*.tsx"],
		"rules": {
			"recommended": true,
			"performance": {
				"noImgElement": "off"
			},
			"suspicious": {
				"noArrayIndexKey": "off",
				"noConsole": "warn",
				"noReactForwardRef": "off"
			},
			"style": {
				"useFilenamingConvention": "off",
				"noMagicNumbers": "off"
			},
			"correctness": {
				"useUniqueElementIds": "off",
				"useExhaustiveDependencies": "warn"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"extends": ["ultracite/biome/react"]
}
